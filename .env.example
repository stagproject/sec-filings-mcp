# Copy to .env and fill in values (never commit .env).
# Supabase: fi_listings_portfolio / fi_listings_portfolio_compact (finance-factory pipeline).

# --- Supabase ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- HTTP server ---
PORT=8081
PUBLIC_MCP_URL=https://sec-edgar-filings.mcp.xpay.sh/mcp

# --- x402 (Polygon USDC) ---
HMAC_SECRET=
SELLER_WALLET_ADDRESS=
BASE_MAINNET=https://mainnet.base.org
POLYGON_MAINNET=https://polygon.publicnode.com
OASIS_MAINNET=
BASE_USDC=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
POLYGON_USDC=0x3c499c542cEF5E3811e1192ce70d8cC03d5c3359
OASIS_WROSE=
ERC20_ABI=[{"constant":true,"inputs":[{"name":"_owner","type":"address"}],"name":"balanceOf","outputs":[{"name":"balance","type":"uint256"}],"type":"function"},{"constant":false,"inputs":[{"name":"_to","type":"address"},{"name":"_value","type":"uint256"}],"name":"transfer","outputs":[{"name":"","type":"bool"}],"type":"function"}]

# --- Pricing (USD list price for purchase_filing) ---
FINANCE_SAMPLE_PRICE_USD=0
